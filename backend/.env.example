# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────
# SQLite (development)
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# PostgreSQL (production — uncomment when ready)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Authentication ────────────────────────────────────
JWT_SECRET=change_this_to_a_64_char_random_string
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP) ─────────────────────────────────────
# Development uses Ethereal (auto-generated test account)
# Production: configure real SMTP
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your_sendgrid_key

# ── Redis (optional, for caching) ────────────────────
# REDIS_URL=redis://localhost:6379
